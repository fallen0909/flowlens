{
  "version": "1.5.1",
  "desktop": {
    "version": "1.5.1",
    "recommendedEntry": "flowlens-desktop.user.js",
    "extensionEntry": "flowlens-extension/manifest.json"
  },
  "mobile": {
    "version": "1.5.1",
    "entry": "flowlens-mobile-all.user.js",
    "loader": "build-time-single-file"
  },
  "source": {
    "versionCenter": "src/core/version.js",
    "shared": "src/core + src/patches",
