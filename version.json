    "diagnostics-log-export",
    "settings-version-display",
    "native-media-filter",
    "core-lightbox-slideshow-control",
    "video-lightbox-favorite",
    "lightbox-nearby-media-preload",
    "gallery-set-queue-navigation",
    "in-place-gallery-queue-switch",
    "direct-bookmark-in-flow-switch",
